// Prisma 7 — generator client mới, output ra src/generated/prisma (giống convention repo mẫu)
generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

// Prisma 7: connection URL chuyển sang prisma.config.ts (datasource.url).
datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  USER
}

enum DishCategory {
  MAIN // món ăn (đồng giá / suất)
  DRINK // đồ uống (tính tiền riêng theo giá)
}

enum PaymentStatus {
  UNPAID // chưa trả
  PENDING // user đã báo chuyển khoản, chờ admin xác nhận
  PAID // admin đã xác nhận nhận tiền
}

/// Tài khoản đăng nhập = thành viên ăn cơm
model User {
  id         String      @id @default(cuid())
  email      String      @unique @db.VarChar(150)
  password   String      @db.VarChar(255)
  fullName   String      @db.VarChar(150)
  role       Role        @default(USER)
  active     Boolean     @default(true)
  color      String?     @db.VarChar(20)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  orders     Order[]
  orderItems OrderItem[]
  notifications Notification[]

  @@map("users")
}

/// Mỗi tuần đặt cơm (tuần hiện tại + lịch sử)
model Week {
  id        String    @id @default(cuid())
  label     String    @db.VarChar(100) // "15/6/2026 - 20/6/2026"
  startDate DateTime? // Ngày Thứ 2 đầu tuần (mốc để khoá tick theo ngày/giờ VN). Null = không khoá.
  unitPrice Int       @default(25000)
  dayMenu   Json? // Thực đơn bán theo ngày: { "mon": [dishId, ...], ... }. Ngày có list -> picker chỉ hiện món đó; ngày trống -> full catalog.
  isActive   Boolean     @default(false)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  orders     Order[]
  orderItems OrderItem[]

  @@map("weeks")
}

/// Đăng ký ăn của 1 user trong 1 tuần (tích ngày)
model Order {
  id        String   @id @default(cuid())
  weekId    String
  userId    String
  mon       Boolean  @default(false)
  tue       Boolean  @default(false)
  wed       Boolean  @default(false)
  thu       Boolean  @default(false)
  fri       Boolean  @default(false)
  sat       Boolean  @default(false)
  sun       Boolean  @default(false)
  paid      Boolean       @default(false) // = (paymentStatus == PAID), giữ cho tương thích
  paymentStatus PaymentStatus @default(UNPAID)
  reportedAt    DateTime? // lúc user bấm "đã chuyển khoản"
  paidAt        DateTime? // lúc admin xác nhận
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  week      Week     @relation(fields: [weekId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([weekId, userId])
  @@map("orders")
}

/// Thông báo trong app (chuông ở header) — báo chuyển khoản / xác nhận thanh toán.
model Notification {
  id        String   @id @default(cuid())
  userId    String // người nhận
  type      String   @db.VarChar(30) // PAYMENT_PENDING | PAYMENT_CONFIRMED | PAYMENT_REJECTED
  title     String   @db.VarChar(150)
  body      String   @db.VarChar(255)
  read      Boolean  @default(false)
  weekId    String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@map("notifications")
}

/// Thực đơn món ăn + đồ uống (admin quản lý)
model Dish {
  id          String       @id @default(cuid())
  name        String       @db.VarChar(150)
  description String?      @db.VarChar(255)
  emoji       String?      @db.VarChar(10)
  price       Int          @default(25000)
  category    DishCategory @default(MAIN)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  orderItems  OrderItem[]

  @@map("dishes")
}

/// Món/đồ uống cụ thể 1 user chọn cho 1 ngày trong tuần (mix nhiều món; nước có số lượng).
/// Suất cơm 25k vẫn tính theo Order.<ngày>; OrderItem.MAIN chỉ là chi tiết, DRINK mới cộng tiền.
model OrderItem {
  id        String   @id @default(cuid())
  weekId    String
  userId    String
  dishId    String
  day       String   @db.VarChar(3) // 'mon'..'sun'
  qty       Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  week      Week     @relation(fields: [weekId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dish      Dish     @relation(fields: [dishId], references: [id], onDelete: Cascade)

  @@index([weekId, userId])
  @@map("order_items")
}

/// Thông tin thanh toán (singleton, admin chỉnh sửa)
model PaymentConfig {
  id            String   @id @default("default")
  groupName     String   @default("Nhóm văn phòng") @db.VarChar(150)
  bankName      String   @default("TPBank") @db.VarChar(100)
  bankBin       String   @default("970423") @db.VarChar(20)
  accountNumber String   @default("10001002966") @db.VarChar(50)
  accountHolder String   @default("NGUYEN ANH KHOA") @db.VarChar(150)
  updatedAt     DateTime @updatedAt

  @@map("payment_config")
}
