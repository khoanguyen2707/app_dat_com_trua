# ===== App =====
NODE_ENV=development
PORT=3000
# Frontend origin cho CORS (vd: https://com-trua.vercel.app). Để * khi dev.
CORS_ORIGIN=*

# ===== Database (Postgres) =====
# Local docker:  postgresql://postgres:postgres@localhost:5432/com_trua?schema=public
# Neon (free):   postgresql://user:pass@ep-xxx.region.aws.neon.tech/com_trua?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/com_trua?schema=public

# ===== JWT =====
JWT_ACCESS_TOKEN_SECRET=doi_thanh_chuoi_bi_mat_access
JWT_ACCESS_TOKEN_EXPIRATION_TIME=7d
JWT_REFRESH_TOKEN_SECRET=doi_thanh_chuoi_bi_mat_refresh
JWT_REFRESH_TOKEN_EXPIRATION_TIME=30d

# ===== Seed admin + dữ liệu mẫu =====
ADMIN_EMAIL=admin@comtrua.vn
ADMIN_PASSWORD=admin123
DEFAULT_PASSWORD=123456
SEED_DEMO=true
